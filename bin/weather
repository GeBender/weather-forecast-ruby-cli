#!/usr/bin/env ruby
# frozen_string_literal: true

require_relative "../lib/weather_app"

begin
  puts Weather::WeatherApp.new.call(ARGV.dup)
  exit 0
rescue Weather::InvalidArgumentsError,
       Weather::InvalidDateError,
       Weather::InvalidCoordinatesError => e
  warn "Input error: #{e.message}"
  exit 1
rescue Weather::ApiUnavailableError => e
  warn "API error: #{e.message}"
  exit 2
rescue Weather::ForecastDateOutOfRangeError,
       Weather::UnexpectedApiResponseError => e
  warn "Forecast error: #{e.message}"
  exit 3
end